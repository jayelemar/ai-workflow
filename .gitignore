# Source-only nested repo: ignore everything by default.
*

# Repo metadata
!/.gitignore
!/README.md
!/AGENTS.md

# Allowlisted source directories
!/changelogs/
!/changelogs/security.changelog.md
!/changelogs/testing.changelog.md
!/changelogs/workflow-state.changelog.md
!/instructions/
!/instructions/shared/
!/instructions/shared/security.md
!/instructions/shared/testing.md
!/instructions/shared/workflow-state.md
!/prompts/
!/prompts/**
!/scripts/
!/scripts/**
!/templates/
!/templates/**
!/wrappers/
!/wrappers/**

# Dynamic/local-only workflow data
/artifacts/
/logs/
/plans/
/specs/
/state/
