# Source-only nested repo: ignore everything by default.
*

# Repo metadata
!/.gitignore
!/README.md

# Allowlisted source directories
!/changelogs/
!/changelogs/index.changelog.md
!/changelogs/security.changelog.md
!/instructions/
!/instructions/index.instructions.md
!/instructions/security.instructions.md
!/prompts/
!/prompts/**
!/scripts/
!/scripts/**
!/templates/
!/templates/**
!/wrappers/
!/wrappers/**

# Dynamic/local-only workflow data
/artifacts/
/logs/
/plans/
/specs/
/state/
